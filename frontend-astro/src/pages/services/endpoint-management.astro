---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import FooterCta from '../../components/FooterCta.astro';
import GlassCard from '../../components/GlassCard.astro';
import { fetchTrackData } from '../../lib/api';
import { ENDPOINT_FALLBACK } from '../../lib/fallbacks';

const track = (await fetchTrackData('endpoint-operations')) ?? ENDPOINT_FALLBACK;
---

<BaseLayout
  title={track.meta_title ?? 'Endpoint Operations | Cyberfyx'}
  description={track.meta_description ?? track.short_summary}
>
  <PageHero
    eyebrow="Service Area"
    headline={track.hero_title}
    lede={track.hero_body}
  >
    <div slot="aside" class="flex-col gap-1">
      <h3 style="font-size: 1.25rem;">Key Offerings</h3>
      <ul style="padding: 0; padding-left: 1.2rem;" class="flex-col gap-1">
        {track.offerings.map(o => <li>{o.kicker || o.title}</li>)}
      </ul>
    </div>
  </PageHero>

  <section class="section">
    <div class="container">
      <div class="grid gap-2" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
        {track.offerings.map((offering, i) => (
          <GlassCard className={`fade-up${i > 0 ? ' delay-100' : ''}`}>
            <h3 class="mb-1 text-xl">{offering.title}</h3>
            {offering.kicker && <p class="offering-kicker">{offering.kicker}</p>}
            <p>{offering.description}</p>
            {offering.taxonomy_terms.length > 0 && (
              <div class="tag-row">
                {offering.taxonomy_terms.map(t => (
                  <span class="offering-tag">{t.label}</span>
                ))}
              </div>
            )}
          </GlassCard>
        ))}
      </div>
    </div>
  </section>

  {track.endpoint_rows.length > 0 && (
    <section class="section" style="padding-top: 0;">
      <div class="container">
        <h2 class="mb-2" style="font-size: 1.4rem;">Product &amp; Solution Catalog</h2>
        <div class="catalog-table-wrap fade-up">
          <table class="catalog-table">
            <thead>
              <tr>
                <th>Product</th>
                <th>Solution</th>
                <th>Service</th>
              </tr>
            </thead>
            <tbody>
              {track.endpoint_rows.map(row => (
                <tr>
                  <td>{row.product_name}</td>
                  <td>{row.solution_name}</td>
                  <td>{row.service_name}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  <FooterCta />
</BaseLayout>

<style>
  .offering-kicker {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-primary);
    margin-bottom: 0.5rem;
  }
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.85rem;
  }
  .offering-tag {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    font-size: 0.72rem;
    font-weight: 500;
    border-radius: 999px;
    background: rgba(53, 29, 117, 0.08);
    color: var(--logo-text-primary);
    border: 1px solid rgba(53, 29, 117, 0.15);
    white-space: nowrap;
  }
  [data-theme="dark"] .offering-tag {
    background: rgba(231, 135, 49, 0.1);
    color: var(--accent-primary);
    border-color: rgba(231, 135, 49, 0.2);
  }
  .catalog-table-wrap {
    overflow-x: auto;
    border-radius: 0.75rem;
    border: 1px solid var(--border-glass);
    background: var(--bg-glass);
    backdrop-filter: blur(12px);
  }
  .catalog-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .catalog-table th {
    padding: 0.85rem 1.1rem;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border-glass);
  }
  .catalog-table td {
    padding: 0.8rem 1.1rem;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-glass);
  }
  .catalog-table tbody tr:last-child td {
    border-bottom: none;
  }
  .catalog-table tbody tr:hover td {
    background: rgba(53, 29, 117, 0.04);
  }
  [data-theme="dark"] .catalog-table tbody tr:hover td {
    background: rgba(231, 135, 49, 0.05);
  }
</style>
