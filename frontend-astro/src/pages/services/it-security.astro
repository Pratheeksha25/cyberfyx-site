---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import FooterCta from '../../components/FooterCta.astro';
import GlassCard from '../../components/GlassCard.astro';
import { fetchTrackData } from '../../lib/api';
import { IT_SECURITY_FALLBACK } from '../../lib/fallbacks';

const track = (await fetchTrackData('it-security')) ?? IT_SECURITY_FALLBACK;
---

<BaseLayout
  title={track.meta_title ?? 'IT Security | Cyberfyx'}
  description={track.meta_description ?? track.short_summary}
>
  <PageHero
    eyebrow="Service Area"
    headline={track.hero_title}
    lede={track.hero_body}
  >
    <div slot="aside" class="flex-col gap-1">
      <h3 style="font-size: 1.25rem;">Key Offerings</h3>
      <ul style="padding: 0; padding-left: 1.2rem;" class="flex-col gap-1">
        {track.offerings.map(o => <li>{o.kicker || o.title}</li>)}
      </ul>
    </div>
  </PageHero>

  <section class="section">
    <div class="container">
      <div class="grid gap-2" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
        {track.offerings.map((offering, i) => (
          <GlassCard className={`fade-up${i > 0 ? ' delay-100' : ''}`}>
            <h3 class="mb-1 text-xl">{offering.title}</h3>
            {offering.kicker && <p class="offering-kicker">{offering.kicker}</p>}
            <p>{offering.description}</p>
            {offering.taxonomy_terms.length > 0 && (
              <div class="tag-row">
                {offering.taxonomy_terms.map(t => (
                  <span class="offering-tag">{t.label}</span>
                ))}
              </div>
            )}
          </GlassCard>
        ))}
      </div>
    </div>
  </section>

  <FooterCta />
</BaseLayout>

<style>
  .offering-kicker {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent-primary);
    margin-bottom: 0.5rem;
  }
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.85rem;
  }
  .offering-tag {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    font-size: 0.72rem;
    font-weight: 500;
    border-radius: 999px;
    background: rgba(53, 29, 117, 0.08);
    color: var(--logo-text-primary);
    border: 1px solid rgba(53, 29, 117, 0.15);
    white-space: nowrap;
  }
  [data-theme="dark"] .offering-tag {
    background: rgba(231, 135, 49, 0.1);
    color: var(--accent-primary);
    border-color: rgba(231, 135, 49, 0.2);
  }
</style>
